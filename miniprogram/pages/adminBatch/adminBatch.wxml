<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="admin-back" bindtap="goBack"></view><text class="admin-title">批次向导</text><text class="admin-chip">{{step}} / 4</text></view>
  <view class="admin-card"><text class="admin-muted">1 基础信息 → 2 SKU库存 → 3 站点窗口 → 4 预览发布</text></view>
  <view wx:if="{{step === 1}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">基础信息</text><input class="admin-input" value="{{name}}" data-key="name" bindinput="onInput" placeholder="批次名称"/><input class="admin-input" value="{{saleDate}}" data-key="saleDate" bindinput="onInput" placeholder="销售日 YYYY-MM-DD"/><input class="admin-input" value="{{pickupDate}}" data-key="pickupDate" bindinput="onInput" placeholder="取货日 YYYY-MM-DD"/><text class="admin-muted">取货日必须是销售日次日；销售日22:00自动停止接单。</text></view>
  <view wx:if="{{step === 2}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">SKU共享库存</text><view wx:for="{{skus}}" wx:key="_id" class="between"><view bindtap="toggleSku" data-id="{{item._id}}"><text class="admin-chip">{{selectedSkus[item._id] ? '✓' : '○'}}</text><text class="admin-text"> {{item.name}} {{item.spec}}</text></view><input class="admin-input" style="width:150rpx" type="number" value="{{inventoryDraft[item._id]}}" data-id="{{item._id}}" bindinput="onInventoryInput"/></view></view>
  <view wx:if="{{step === 3}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">站点与自提窗口</text><text class="admin-muted">每站累计满5件；门槛不可编辑。</text><view wx:for="{{stations}}" wx:key="_id" class="admin-window-row"><view class="between" bindtap="toggleStation" data-id="{{item._id}}"><text class="admin-text">{{item.name}}</text><text class="admin-chip">{{selectedStations[item._id] ? '已选' : '未选'}}</text></view><view class="row gap-sm"><input class="admin-input" value="{{stationWindows[item._id].arriveAt}}" data-id="{{item._id}}" data-key="arriveAt" bindinput="onWindowInput"/><input class="admin-input" value="{{stationWindows[item._id].leaveAt}}" data-id="{{item._id}}" data-key="leaveAt" bindinput="onWindowInput"/></view><input class="admin-input" value="{{stationWindows[item._id].locationNote}}" data-id="{{item._id}}" data-key="locationNote" bindinput="onWindowInput"/><view class="admin-btn ghost" bindtap="addWindowImage" data-id="{{item._id}}">上传地点图片（最多3张）</view></view></view>
  <view wx:if="{{step === 4}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">预览并手动发布</text><text class="admin-text">{{name}}</text><text class="admin-muted">{{saleDate}} 22:00截单 · {{pickupDate}}取货 · 每站5件</text><text class="admin-muted">发布前仍可保存草稿；发布后不会自动生成下一批。</text><view class="admin-btn ghost" bindtap="saveDraft">保存草稿</view><view class="admin-btn" bindtap="publish">确认手动发布</view></view>
  <view class="row gap-sm" style="margin:24rpx 0"><view wx:if="{{step > 1}}" class="admin-btn ghost" style="flex:1" bindtap="prev">上一步</view><view wx:if="{{step < 4}}" class="admin-btn" style="flex:1" bindtap="next">下一步</view></view>
</view>
