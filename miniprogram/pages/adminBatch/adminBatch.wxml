<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="admin-back" bindtap="goBack"></view><text class="admin-title">批次发布</text><text class="admin-chip">简化发布</text></view>
  <view class="admin-card column gap-sm"><text class="admin-card-title">基础信息</text><input class="admin-input" value="{{name}}" data-key="name" bindinput="onInput"/><input class="admin-input" value="{{saleDate}}" data-key="saleDate" bindinput="onInput"/><input class="admin-input" value="{{pickupDate}}" data-key="pickupDate" bindinput="onInput"/><text class="admin-muted {{latePublishWarning ? 'orange' : ''}}">建议每天 10:00 前发布，这是软提醒，不阻断发布。</text></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">勾选 SKU + 填库存</text><view wx:for="{{skus}}" wx:key="_id" class="between"><view bindtap="toggleSku" data-id="{{item._id}}"><text class="admin-chip">{{selectedSkus[item._id] ? '✓' : '○'}}</text><text class="admin-text"> {{item.name}} {{item.spec}}</text></view><input class="admin-input" style="width:150rpx" type="number" value="{{inventoryDraft[item._id]}}" data-id="{{item._id}}" bindinput="onInventoryInput"/></view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">勾选启用站点</text><text class="admin-muted">窗口、地点、图片和核销模式沿用站点固定资料，发布时不重复填写。</text><view wx:for="{{stations}}" wx:key="_id" class="between" bindtap="toggleStation" data-id="{{item._id}}"><text class="admin-text">{{item.name}} · {{item.verifyMode}}</text><text class="admin-chip">{{selectedStations[item._id] ? '已选' : '未选'}}</text></view></view>
  <view class="row gap-sm" style="margin-top:24rpx"><view class="admin-btn ghost" style="flex:1" bindtap="saveDraft">保存草稿</view><view class="admin-btn" style="flex:1" bindtap="publish">确认手动发布</view></view>
</view>
