<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="admin-back" bindtap="goBack"></view><view><text class="admin-title">泰斓工作台</text><text class="admin-sub">{{isSuperAdmin ? '超级管理员' : '核销员 · 仅授权站点'}}</text></view><text class="admin-chip">{{role}}</text></view>
  <view class="admin-card outline column gap-sm"><text class="admin-card-title">现场履约</text><view class="admin-btn" bindtap="goVerify">进入备料与核销</view></view>
  <view wx:if="{{isSuperAdmin}}" class="admin-card column gap-sm" style="margin-top:24rpx"><view class="between"><text class="admin-card-title">今日营业</text><text class="admin-chip">{{businessStatus}}</text></view><text class="admin-muted">催开团 {{nudgeCount}} 人</text><view class="admin-btn ghost" bindtap="toggleTodayRest">{{businessStatus === '今日休息' ? '取消今日休息' : '设为今日休息'}}</view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">授权站点</text><view wx:for="{{stationCards}}" wx:key="_id" class="column gap-xs"><view class="between"><text class="admin-text">{{item.name}}</text><text class="admin-chip">{{item.status}}</text></view><text class="admin-muted">{{item.peopleProgress}} · 待自提 {{item.pendingCount}} 单</text><view wx:if="{{isSuperAdmin}}" class="row gap-sm"><view class="admin-btn ghost" style="flex:1" bindtap="manualConfirm" data-id="{{item._id}}">低于5人手动确认配送</view><view class="admin-btn warn" style="flex:1" bindtap="closeStation" data-id="{{item._id}}">成团后手动取消配送</view><view class="admin-btn warn" style="flex:1" bindtap="closeBatch" data-id="{{item.batchId}}">关闭整批</view></view><view class="admin-divider"></view></view></view>
  <view wx:if="{{isSuperAdmin}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">待处理退款申请（{{pendingRefundRequests.length}}）</text><view wx:for="{{pendingRefundRequests}}" wx:key="_id" class="column gap-xs"><text class="admin-text">订单 {{item.orderId}}</text><text class="admin-muted">{{item.reason || '交付后退款申请'}}</text><view class="row gap-sm"><view class="admin-btn" style="flex:1" data-id="{{item.orderId}}" data-decision="refund" bindtap="resolveRefund">同意退款</view><view class="admin-btn warn" style="flex:1" data-id="{{item.orderId}}" data-decision="reject" bindtap="resolveRefund">驳回</view></view></view></view>
  <view wx:if="{{isSuperAdmin}}" class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">核销员授权</text><input class="admin-input" placeholder="核销员 openid" value="{{verifierOpenid}}" data-key="verifierOpenid" bindinput="onAuthInput"/><input class="admin-input" placeholder="批次ID（可空）" value="{{verifierBatchId}}" data-key="verifierBatchId" bindinput="onAuthInput"/><input class="admin-input" placeholder="站点ID，逗号分隔" value="{{verifierStationIds}}" data-key="verifierStationIds" bindinput="onAuthInput"/><view class="admin-btn" bindtap="assignVerifier">保存核销权限</view></view>
  <view wx:if="{{isSuperAdmin}}" class="admin-grid" style="margin-top:24rpx"><view class="admin-tile" bindtap="goProducts"><text class="admin-text">商品管理</text></view><view class="admin-tile" bindtap="goBatch"><text class="admin-text">批次向导</text></view><view class="admin-tile" bindtap="goStations"><text class="admin-text">站点管理</text></view></view>
</view>
