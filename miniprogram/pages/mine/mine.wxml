<view class="screen with-tab mine-screen">
  <view class="card column gap-md">
    <view class="row gap-md">
      <image wx:if="{{user.avatarFileId}}" class="avatar-large" src="{{user.avatarFileId}}" mode="aspectFill"></image>
      <view wx:else class="avatar-large avatar-placeholder">我</view>
      <view class="column gap-xs" style="flex: 1;">
        <text class="tag">我的</text>
        <text class="section-title">{{user.nickname || '微信用户'}}</text>
        <text class="small">手机号仅在下单支付前补充</text>
      </view>
    </view>
  </view>

  <view class="card column gap-sm" style="margin-top: 24rpx;">
    <text class="card-title">订单摘要</text>
    <view class="row gap-sm">
      <view class="summary-pill" bindtap="goOrders" data-status="处理中"><text class="price">{{orderSummary.forming}}</text><text class="small">处理中</text></view>
      <view class="summary-pill" bindtap="goOrders" data-status="待自提"><text class="price">{{orderSummary.pickup}}</text><text class="small">待自提</text></view>
      <view class="summary-pill" bindtap="goOrders" data-status="all"><text class="price">{{orderSummary.total}}</text><text class="small">全部订单</text></view>
    </view>
  </view>

  <view class="card column gap-md" style="margin-top: 24rpx;">
    <button class="list-button" open-type="contact"><text class="card-title" style="flex: 1;">联系商家</text><text class="small">微信客服</text></button>
    <view class="divider"></view>
    <view class="list-item" bindtap="goRules"><text class="card-title" style="flex: 1;">规则说明</text><text class="small">拼团与退款</text></view>
  </view>

  <view wx:if="{{isAdmin}}" class="card column gap-md" style="margin-top: 24rpx;">
    <text class="tag">管理员 · {{role}}</text>
    <view class="list-item" bindtap="goAdmin"><text class="card-title" style="flex: 1;">商家管理</text><text class="small">进入</text></view>
    <view class="divider"></view>
    <view class="list-item" bindtap="goVerify"><text class="card-title" style="flex: 1;">现场核销</text><text class="small">进入</text></view>
  </view>

  <view class="merchant-channel" bindtap="openMerchantChannel">商家通道</view>
  <rule-sheet visible="{{showRules}}" bind:close="closeRules" />
</view>
