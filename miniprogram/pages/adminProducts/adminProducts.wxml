<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="row gap-sm"><view class="admin-back" bindtap="goBack"></view><text class="admin-title">商品管理</text></view><text class="admin-chip">superAdmin</text></view>
  <view class="column gap-sm"><view wx:for="{{products}}" wx:key="_id" class="admin-card row gap-sm" bindtap="pickProduct" data-id="{{item._id}}" style="{{item._id === productId ? 'border: 2rpx solid #7BC96F;' : ''}}"><view class="thumb" style="width: 96rpx; height: 96rpx;"><image wx:if="{{item.images && item.images[0]}}" class="thumb-image" src="{{item.images[0]}}" mode="aspectFill"></image><view wx:else class="cake"></view></view><view style="flex: 1;"><text class="admin-card-title">{{item.name}}</text><text class="admin-muted">{{item.status}} · 可编辑商品与SKU</text></view><text class="admin-chip">{{item.status}}</text></view></view>
  <view class="admin-card column gap-sm" style="margin-top: 24rpx;">
    <view class="between"><text class="admin-card-title">{{productId ? "编辑商品" : "新增商品"}}</text><view class="row gap-sm"><view class="admin-btn ghost" style="padding: 6rpx 20rpx;" bindtap="toggleProductStatus">{{productStatus}}</view><view class="admin-btn ghost" style="padding: 6rpx 20rpx;" bindtap="newProduct">＋新商品</view></view></view>
    <view class="row gap-sm"><view class="admin-btn ghost" style="width: 180rpx;" bindtap="chooseImage">上传图片</view><text class="admin-muted">wx.chooseMedia + wx.cloud.uploadFile</text></view>
    <view wx:if="{{imageFileIds.length}}" class="image-grid"><view wx:for="{{imageFileIds}}" wx:key="*this" class="image-cell"><image class="image-cell-img" src="{{item}}" mode="aspectFill"></image><view class="image-remove" bindtap="removeImage" data-index="{{index}}">删除</view></view></view>
    <text class="admin-label">商品名称</text><input class="admin-input" value="{{productName}}" data-key="productName" bindinput="onInput" />
    <text class="admin-label">泰文名</text><input class="admin-input" value="{{productThaiName}}" data-key="productThaiName" bindinput="onInput" />
    <text class="admin-label">分类</text><input class="admin-input" value="{{productCategory}}" data-key="productCategory" bindinput="onInput" />
    <text class="admin-label">标签（顿号分隔）</text><input class="admin-input" value="{{productTags}}" data-key="productTags" bindinput="onInput" />
    <text class="admin-label">商品描述</text><input class="admin-input" value="{{productDesc}}" data-key="productDesc" bindinput="onInput" />
    <view class="admin-btn" bindtap="saveProduct">保存商品</view>
  </view>
  <view class="admin-card column gap-sm" style="margin-top: 24rpx;"><text class="admin-card-title">SKU 管理</text><view wx:for="{{productSkus}}" wx:key="_id" class="between" bindtap="pickSku" data-id="{{item._id}}" style="{{item._id === skuId ? 'border-left: 6rpx solid #7BC96F; padding-left: 8rpx;' : ''}}"><text class="admin-text">{{item.name}} · {{item.spec}}</text><text class="admin-chip {{item.status === '上架' ? '' : 'orange'}}">{{item.status}} · ¥{{item.price / 100}}</text></view><view class="admin-btn ghost" style="padding: 6rpx 20rpx; align-self: flex-start;" bindtap="newSku">＋新SKU（当前商品下）</view><view class="admin-divider"></view><text class="admin-label">SKU 名</text><input class="admin-input" value="{{skuName}}" data-key="skuName" bindinput="onInput" /><text class="admin-label">规格</text><input class="admin-input" value="{{skuSpec}}" data-key="skuSpec" bindinput="onInput" /><text class="admin-label">价格（分）</text><input class="admin-input" type="number" value="{{skuPrice}}" data-key="skuPrice" bindinput="onInput" /><view class="row gap-sm"><view class="admin-btn" style="flex: 1;" bindtap="saveSku" data-status="上架">保存上架</view><view class="admin-btn warn" style="flex: 1;" bindtap="saveSku" data-status="下架">保存下架</view></view><text class="admin-muted">改价只影响后续新订单，已付订单金额看 orders.items 价格快照。</text></view>
</view>
