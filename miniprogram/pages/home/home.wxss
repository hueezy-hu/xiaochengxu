@import "../../styles/common.wxss";
.home-screen { min-height: 100vh; box-sizing: border-box; padding: 0 32rpx 44rpx; background: #FAF7EE; }
.home-hero { position: relative; height: 690rpx; margin: 0 -32rpx; overflow: hidden; background: #DFF0D2; }
.home-hero-img, .home-hero-fallback { position: absolute; inset: 0; width: 100%; height: 100%; }
.home-hero-fallback { display: flex; align-items: center; justify-content: center; transform: scale(1.8); opacity: .95; }
.home-hero-mask { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(23,40,28,.34), rgba(23,40,28,0) 42%, rgba(23,40,28,.42)); }
.home-brand { position: absolute; left: 40rpx; top: 132rpx; display: flex; flex-direction: column; gap: 6rpx; }
.home-brand-title { color: #fff; font-size: 32rpx; font-weight: 900; letter-spacing: 2rpx; }
.home-brand-sub { color: rgba(255,255,255,.86); font-size: 20rpx; letter-spacing: 4rpx; }
.home-hero-copy { position: absolute; left: 40rpx; right: 40rpx; bottom: 90rpx; display: flex; flex-direction: column; gap: 12rpx; }
.home-hero-title { color: #fff; font-size: 46rpx; font-weight: 900; line-height: 1.25; text-shadow: 0 4rpx 14rpx rgba(23,40,28,.28); }
.home-hero-sub { color: rgba(255,255,255,.92); font-size: 25rpx; font-weight: 700; line-height: 1.35; }
.home-entry { margin-top: -64rpx; position: relative; z-index: 2; padding: 12rpx 8rpx; }
.home-pickup { display: flex; align-items: center; gap: 24rpx; padding: 26rpx 34rpx; }
.home-icon { width: 88rpx; height: 88rpx; border-radius: 24rpx; background: #EDF7EC; color: #3E8E5E; display: flex; align-items: center; justify-content: center; font-weight: 900; }
.home-arrow { color: #3E8E5E; font-size: 48rpx; font-weight: 400; }
.home-shortcuts { display: flex; align-items: stretch; }
.home-shortcut { flex: 1; height: 104rpx; display: flex; align-items: center; justify-content: center; color: #243329; font-size: 26rpx; font-weight: 800; background: transparent; border: 0; padding: 0; margin: 0; }
.home-shortcut::after { border: 0; }
.home-batch-card { margin-top: 24rpx; }
.home-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; }
.home-step { min-height: 172rpx; border-radius: 24rpx; background: #FAF7EE; padding: 18rpx; box-sizing: border-box; display: flex; flex-direction: column; gap: 8rpx; }
.home-step.active { background: #EDF7EC; }
.home-step-num { width: 36rpx; height: 36rpx; border-radius: 50%; background: #3E8E5E; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 900; }
.home-step-title { color: #243329; font-size: 25rpx; font-weight: 900; line-height: 1.25; }
.home-rule-line { margin-top: 20rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.welcome-mask { position: fixed; inset: 0; z-index: 50; display: flex; align-items: flex-end; background: rgba(16,24,18,.38); }
.welcome-sheet { width: 100%; box-sizing: border-box; padding: 38rpx 32rpx 52rpx; border-radius: 32rpx 32rpx 0 0; background: #fff; display: flex; flex-direction: column; gap: 22rpx; box-shadow: 0 -16rpx 48rpx rgba(25,46,30,.18); }
.welcome-title { color: #243329; font-size: 36rpx; font-weight: 900; }
.welcome-copy { color: #57614F; font-size: 26rpx; line-height: 1.45; }
.welcome-avatar { align-self: flex-start; padding: 0; margin: 0; background: transparent; border: 0; }
.welcome-avatar::after { border: 0; }
.welcome-skip { height: 76rpx; display: flex; align-items: center; justify-content: center; color: #7C8577; font-size: 26rpx; font-weight: 800; }

.home-station-card { margin-top: 20rpx; }
.home-rule-card { margin-top: 20rpx; }
