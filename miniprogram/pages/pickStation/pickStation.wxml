<view class="screen" style="padding-bottom:180rpx">
  <view class="topbar"><view class="back" bindtap="goBack"></view><text class="nav-title">选自提站点</text><view class="menu-pill">•••</view></view>
  <view class="notice">每站满 5 人成团配送；商品库存仍按份计算。</view>
  <view class="column gap-md" style="margin-top:24rpx">
    <view wx:for="{{stations}}" wx:key="_id" class="station-card {{selectedId === item._id ? 'active' : ''}}" bindtap="selectStation" data-id="{{item._id}}">
      <view class="between"><view class="column gap-xs"><text class="card-title">{{item.stationName}}</text><text class="small">{{item.line}} · {{item.exit}}</text></view><text class="tag">{{item.verifyMode}}</text></view>
      <view class="between"><text class="text">已拼 {{item.paid}}/{{item.threshold}} 人</text><text class="small">{{item.leftText}}</text></view><view class="progress"><view class="progress-inner" style="width:{{item.percent}}%"></view></view>
      <text class="small">{{item.windowText}} · {{item.locationNote}}</text>
    </view>
  </view>
  <view class="fixed-bottom between"><text class="small">{{summaryText}}</text><view class="btn {{selectedId ? '' : 'disabled'}}" style="width:240rpx" bindtap="next">下一步</view></view>
</view>
