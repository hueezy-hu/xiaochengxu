<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="admin-back" bindtap="goBack"></view><text class="admin-title">现场核销</text><text class="admin-chip">{{verifyMode}}</text></view>
  <view class="admin-card column gap-sm"><picker range="{{stationOptions}}" range-key="label" value="{{stationIndex}}" bindchange="onStationChange"><view class="admin-input">{{stationOptions[stationIndex].label || '暂无可自提站点'}}</view></picker><text class="admin-muted">先上传到点/放置照片，再做尾号核销、扫码或整场放置。</text><view class="admin-btn ghost" bindtap="chooseProof">上传交付照片（1-3张）</view><text class="admin-muted">已上传 {{proofImages.length}} 张；上传失败不会改变订单。</text><text wx:if="{{duplicateTailWarnings.length}}" class="admin-chip orange">同场次尾号重复预警 {{duplicateTailWarnings.length}} 组</text></view>
  <view wx:if="{{verifyMode === '有人核销'}}" class="admin-card column gap-sm" style="margin-top:24rpx"><input class="admin-input" style="text-align:center;font-size:54rpx" type="number" maxlength="4" value="{{phoneTail}}" bindinput="onTail" placeholder="输入手机尾号"/><view class="row gap-sm"><view class="admin-btn" style="flex:1" bindtap="verifyTail">尾号核销</view><view class="admin-btn ghost" style="flex:1" bindtap="scanCode">扫二维码</view></view><view wx:for="{{candidates}}" wx:key="orderId" class="between"><text class="admin-text">{{item.phoneTail}} · {{item.contactName || item.orderId}}</text><view class="admin-btn ghost" data-id="{{item.orderId}}" bindtap="verifyCandidate">选择此单</view></view></view>
  <view wx:else class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">无人放置交付</text><text class="admin-muted">确认整场订单与照片后一次性标记已放置。</text><view class="admin-btn" bindtap="placeAll">整场已放置</view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><view class="between"><text class="admin-card-title">本场进度</text><text class="admin-chip">{{doneCount}} / {{totalCount}}</text></view><view class="admin-progress"><view class="admin-progress-inner" style="width:{{percent}}%"></view></view><view class="column gap-sm"><view class="admin-btn ghost" bindtap="markArrived">我已到达</view><view class="admin-danger-zone column gap-sm"><text class="admin-label">收尾操作</text><view wx:if="{{verifyMode === '有人核销'}}" class="admin-btn warn" bindtap="finishNoShow">未取收尾</view><view class="admin-btn warn" bindtap="endPickup">结束本场</view></view></view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">备料与订单</text><view wx:for="{{prepSummary}}" wx:key="sku" class="between"><text>{{item.sku}}</text><text>× {{item.count}}</text></view><view class="admin-divider"></view><view wx:for="{{orders}}" wx:key="_id" class="column gap-xs"><view class="between"><text>尾号 {{item.phoneTail}} · {{item.phone}}</text><text class="admin-chip">{{item.status}}</text></view><view wx:if="{{item.status === '待自提' && verifyMode === '有人核销'}}" class="admin-btn ghost" bindtap="contact" data-id="{{item._id}}">联系用户</view><view class="admin-divider"></view></view></view>
</view>
