<view class="admin-screen" wx:if="{{allowed}}">
  <view class="admin-topbar"><view class="admin-back" bindtap="goBack"></view><text class="admin-title">现场核销</text><text class="admin-chip">{{role}}</text></view>
  <view class="admin-card column gap-sm"><text class="admin-label">当前授权站点</text><picker range="{{stationOptions}}" range-key="label" value="{{stationIndex}}" bindchange="onStationChange"><view class="admin-input">{{stationOptions[stationIndex].label || '暂无可自提站点'}}</view></picker></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><input class="admin-input" style="text-align:center;font-size:54rpx" type="number" maxlength="6" value="{{code}}" bindinput="onCode" placeholder="输入6位码"/><view class="row gap-sm"><view class="admin-btn" style="flex:1" bindtap="verify">核销</view><view class="admin-btn ghost" style="flex:1" bindtap="scanCode">扫码</view></view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><view class="between"><text class="admin-card-title">本场进度</text><text class="admin-chip">{{doneCount}} / {{totalCount}}</text></view><view class="admin-progress"><view class="admin-progress-inner" style="width:{{percent}}%"></view></view><view class="row gap-sm"><view class="admin-btn ghost" style="flex:1" bindtap="markArrived">我已到达</view><view class="admin-btn warn" style="flex:1" bindtap="endPickup">结束本场</view></view></view>
  <view class="admin-card column gap-sm" style="margin-top:24rpx"><text class="admin-card-title">备料与订单</text><view wx:for="{{prepSummary}}" wx:key="sku" class="between"><text>{{item.sku}}</text><text>× {{item.count}}</text></view><view class="admin-divider"></view><view wx:for="{{orders}}" wx:key="_id" class="column gap-xs"><view class="between"><text>{{item.verifyCode}} · {{item.phone}}</text><text class="admin-chip">{{item.status}}</text></view><view wx:if="{{item.status === '待自提'}}" class="row gap-sm"><view class="admin-btn ghost" style="flex:1" bindtap="contact" data-id="{{item._id}}">联系用户</view><view class="admin-btn ghost" style="flex:1" bindtap="place" data-id="{{item._id}}">固定地点放置</view></view><view class="admin-divider"></view></view></view>
</view>
